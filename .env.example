# Clé API Anthropic (obligatoire)
ANTHROPIC_API_KEY=sk-ant-...

# URL interne du gateway Open Claw (ne pas changer en Docker)
OPENCLAW_GATEWAY_URL=ws://openclaw-gateway:18789

# Token d'accès gateway Open Claw (généré par setup.js)
OPENCLAW_GATEWAY_TOKEN=

# Origin publique autorisée pour l'UI
PIXEL_UI_ORIGIN=http://localhost:3333

# Publication du port gateway côté hôte
OPENCLAW_GATEWAY_PORT_BIND=127.0.0.1:18789:18789

# Port de l'UI (défaut 3333)
PORT=3333
